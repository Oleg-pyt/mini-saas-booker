# ──────────────────────────────────────────────────────────────────────────────
# Environment Configuration Example
#
# Copy this file to .env and adjust values for your environment
# .env is loaded by docker-compose and Spring Boot
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Database name
POSTGRES_DB=platform

# Database user
POSTGRES_USER=postgres

# Database password (change in production!)
POSTGRES_PASSWORD=postgres

# Database host (use service name in Docker: platform-postgres)
POSTGRES_HOST=platform-postgres

# Database port (internal Docker network port)
POSTGRES_PORT=5432

# ──────────────────────────────────────────────────────────────────────────────
# Spring Boot Configuration
# ──────────────────────────────────────────────────────────────────────────────

# JDBC connection URL
SPRING_DATASOURCE_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Database username
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}

# Database password
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# Logging
LOGGING_LEVEL_ROOT=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Application Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Server port
SERVER_PORT=8080

# Environment profile (dev, prod, etc.)
SPRING_PROFILES_ACTIVE=dev

