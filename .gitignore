################################

# Ignore folders in all depths

################################
**/.idea/
**/target/
**/.generated/
**/.angular/
**/dist/
**/node_modules/

################################

# Default Java files

################################
**/*.class
**/*.log
**/*.jar
**/*.war
**/*.ear
**/*.nar

################################

# OS files

################################
**/.DS_Store
**/Thumbs.db

################################

# IDE

################################
**/*.iml
**/.vscode/

################################

# Environment

################################
.env
.env.local
.env.*.local

# Allow example/template env file
!.env.example

################################

# Logs

################################
**/logs/
**/*.log
